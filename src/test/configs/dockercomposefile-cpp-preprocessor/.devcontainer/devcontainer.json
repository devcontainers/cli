{
	"name": "Docker Compose Cpp Preprocessor",
	"dockerComposeFile": "docker-compose.yml",
	"service": "app",
	"workspaceFolder": "/workspace",
	"dockerfilePreprocessor": {
		"tool": "cpp",
		"outputMode": "single-file",
		"args": [
			"-P"
		]
	},
	"features": {
		"ghcr.io/devcontainers/features/github-cli:1": {
			"version": "latest"
		}
	}
}
