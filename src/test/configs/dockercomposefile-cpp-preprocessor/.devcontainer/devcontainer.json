{
	"name": "Docker Compose Cpp Preprocessor",
	"dockerComposeFile": "docker-compose.yml",
	"service": "app",
	"workspaceFolder": "/workspace",
	"dockerfilePreprocessor": {
		"tool": "cpp",
		"generatedDockerfilePath": "Dockerfile",
		"args": [
			"-P",
			"Dockerfile.in",
			"Dockerfile"
		]
	},
	"features": {
		"ghcr.io/devcontainers/features/git": "latest"
	}
}
